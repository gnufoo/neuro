[Unit]
Description=Neuro - Programmable Timer Engine with MCP Interface
After=network.target

[Service]
Type=simple
User=neuro
Group=neuro
ExecStart=/usr/local/bin/neuro -c /etc/neuro/neuro.toml
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/neuro /var/log/neuro

[Install]
WantedBy=multi-user.target
